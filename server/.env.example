# Server port
PORT=5000

# MongoDB connection string (MongoDB Atlas or local)
# Example Atlas URI: mongodb+srv://<user>:<password>@cluster0.mongodb.net
MONGODB_URI=mongodb://127.0.0.1:27017

# Name of the database Mongoose should use (appended to MONGODB_URI)
DB_NAME=hotel-booking

# Clerk secret key (from https://dashboard.clerk.com -> API Keys)
# Used server-side to verify session tokens sent by the React app
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma separated list of origins allowed to call this API
CLIENT_URL=http://localhost:5173
